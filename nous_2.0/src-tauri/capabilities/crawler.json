{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "allow-node-execution",
    "description": "Allows the app to execute node processes for the crawler",
    "windows": [
        "main"
    ],
    "permissions": [
        {
            "identifier": "shell:allow-execute",
            "allow": [
                {
                    "program": "node",
                    "args": true
                }
            ]
        }
    ]
}